<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="userinterface.VenuePanel">
  <grid id="27dc6" binding="mainPanel" layout-manager="BorderLayout" hgap="10" vgap="10">
    <constraints>
      <xy x="20" y="20" width="900" height="700"/>
    </constraints>
    <properties/>
    <border type="empty">
      <size top="10" left="10" bottom="10" right="10"/>
    </border>
    <children>
      <grid id="a1b2c" layout-manager="BorderLayout" hgap="0" vgap="5">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="formPanel" layout-manager="GridBagLayout">
            <constraints border-constraint="Center"/>
            <properties/>
            <border type="etched" title="Venue Information"/>
            <children>
              <component id="d3e4f" class="javax.swing.JLabel">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                  <gridbag weightx="0.0" weighty="0.0"/>
                </constraints>
                <properties>
                  <text value="Name:"/>
                </properties>
              </component>
              <component id="f5g6h" class="javax.swing.JTextField" binding="nameField">
                <constraints>
                  <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                    <preferred-size width="250" height="-1"/>
                  </grid>
                  <gridbag weightx="1.0" weighty="0.0"/>
                </constraints>
                <properties/>
              </component>
              <component id="h7i8j" class="javax.swing.JLabel">
                <constraints>
                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                  <gridbag weightx="0.0" weighty="0.0"/>
                </constraints>
                <properties>
                  <text value="City:"/>
                </properties>
              </component>
              <component id="j9k0l" class="javax.swing.JTextField" binding="cityField">
                <constraints>
                  <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                    <preferred-size width="250" height="-1"/>
                  </grid>
                  <gridbag weightx="1.0" weighty="0.0"/>
                </constraints>
                <properties/>
              </component>
              <component id="l1m2n" class="javax.swing.JLabel">
                <constraints>
                  <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                  <gridbag weightx="0.0" weighty="0.0"/>
                </constraints>
                <properties>
                  <text value="Address:"/>
                </properties>
              </component>
              <component id="n3o4p" class="javax.swing.JTextField" binding="addressField">
                <constraints>
                  <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                    <preferred-size width="250" height="-1"/>
                  </grid>
                  <gridbag weightx="1.0" weighty="0.0"/>
                </constraints>
                <properties/>
              </component>
              <component id="p5q6r" class="javax.swing.JLabel">
                <constraints>
                  <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                  <gridbag weightx="0.0" weighty="0.0"/>
                </constraints>
                <properties>
                  <text value="Capacity:"/>
                </properties>
              </component>
              <component id="r7s8t" class="javax.swing.JTextField" binding="capacityField">
                <constraints>
                  <grid row="3" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                    <preferred-size width="150" height="-1"/>
                  </grid>
                  <gridbag weightx="1.0" weighty="0.0"/>
                </constraints>
                <properties/>
              </component>
              <component id="t9u0v" class="javax.swing.JLabel">
                <constraints>
                  <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="9" fill="0" indent="0" use-parent-layout="false"/>
                  <gridbag weightx="0.0" weighty="0.0"/>
                </constraints>
                <properties>
                  <text value="Facilities (one per line):"/>
                </properties>
              </component>
              <scrollpane id="v1w2x" binding="facilitiesScrollPane">
                <constraints>
                  <grid row="4" column="1" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false">
                    <preferred-size width="250" height="80"/>
                  </grid>
                  <gridbag weightx="1.0" weighty="1.0"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="x3y4z" class="javax.swing.JTextArea" binding="facilitiesArea">
                    <constraints/>
                    <properties>
                      <lineWrap value="true"/>
                      <rows value="3"/>
                      <wrapStyleWord value="true"/>
                    </properties>
                  </component>
                </children>
              </scrollpane>
            </children>
          </grid>
          <grid id="buttonPanel" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
            <constraints border-constraint="South"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="z5a6b" class="javax.swing.JButton" binding="addButton">
                <constraints/>
                <properties>
                  <text value="Add Venue"/>
                </properties>
              </component>
              <component id="b7c8d" class="javax.swing.JButton" binding="deleteButton">
                <constraints/>
                <properties>
                  <text value="Delete Selected"/>
                </properties>
              </component>
              <component id="d9e0f" class="javax.swing.JButton" binding="clearButton">
                <constraints/>
                <properties>
                  <text value="Clear Form"/>
                </properties>
              </component>
              <component id="f1g2h" class="javax.swing.JButton" binding="viewButton">
                <constraints/>
                <properties>
                  <text value="View Details"/>
                </properties>
              </component>
              <component id="i5j6k" class="javax.swing.JButton" binding="editDetailsButton">
                <constraints/>
                <properties>
                  <text value="Edit Details"/>
                </properties>
              </component>
            </children>
          </grid>
        </children>
      </grid>
      <scrollpane id="tableScroll" binding="tableScrollPane">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="h3i4j" class="javax.swing.JTable" binding="venueTable">
            <constraints/>
            <properties/>
          </component>
        </children>
      </scrollpane>
    </children>
  </grid>
</form>
