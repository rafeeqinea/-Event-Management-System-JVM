<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="userinterface.StatisticsPanel">
  <grid id="27dc6" binding="mainPanel" layout-manager="BorderLayout" hgap="10" vgap="10">
    <constraints>
      <xy x="20" y="20" width="900" height="700"/>
    </constraints>
    <properties/>
    <border type="empty">
      <size top="20" left="20" bottom="20" right="20"/>
    </border>
    <children>
      <component id="title1" class="javax.swing.JLabel" binding="titleLabel">
        <constraints border-constraint="North"/>
        <properties>
          <font size="24" style="1"/>
          <horizontalAlignment value="0"/>
          <text value="Application Statistics"/>
        </properties>
      </component>
      <grid id="content1" binding="contentPanel" layout-manager="GridLayout" row-count="2" column-count="2" hgap="15" vgap="15" same-size-horizontally="false" same-size-vertically="false">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <margin top="0" left="0" bottom="0" right="0"/>
        <children/>
      </grid>
      <grid id="btnPanel" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
        <constraints border-constraint="South"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="btn1" class="javax.swing.JButton" binding="refreshButton">
            <constraints/>
            <properties>
              <text value="Refresh Statistics"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
